{
  "version": 2,
  "name": "school-erp-fullstack",
  "builds": [
    {
      "src": "school-erp-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "installCommand": "npm install",
        "buildCommand": "npm run build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://votre-api-dotnet.com/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "school-erp-frontend/$1",
      "check": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "status": 200,
      "dest": "school-erp-frontend/index.html"
    }
  ]
}
