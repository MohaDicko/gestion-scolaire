{
  "version": 2,
  "framework": "nextjs",
  "functions": {
    "src/app/api/**/*": {
      "maxDuration": 30,
      "memory": 2048
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "x-deployment-id",
          "value": "$VERCEL_DEPLOYMENT_ID"
        }
      ]
    }
  ]
}
