generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id              String         @id @default(uuid())
  name            String
  code            String         @unique
  address         String
  city            String
  country         String
  phoneNumber     String
  email           String
  type            SchoolType
  drenCode        String?
  isActive        Boolean        @default(true)
  isSetupComplete Boolean        @default(false)
  logoUrl         String?
  motto           String?
  nationalRNE     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  academicYears   AcademicYear[]
  campuses        Campus[]
}

model Campus {
  id          String      @id @default(uuid())
  tenantId    String
  name        String
  address     String
  city        String
  region      String
  phoneNumber String
  email       String?
  managerName String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  school      School      @relation(fields: [tenantId], references: [id])
  classrooms  Classroom[]
  students    Student[]
}

model AcademicYear {
  id          String       @id @default(uuid())
  tenantId    String
  name        String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean      @default(false)
  school      School       @relation(fields: [tenantId], references: [id])
  classrooms  Classroom[]
  enrollments Enrollment[]
  grades      Grade[]
}

model Classroom {
  id             String       @id @default(uuid())
  tenantId       String
  campusId       String
  academicYearId String
  name           String
  level          String
  stream         String?
  series         String?
  maxCapacity    Int
  Attendance     Attendance[]
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  campus         Campus       @relation(fields: [campusId], references: [id])
  enrollments    Enrollment[]
  Timetable      Timetable[]
}

model Student {
  id                 String       @id @default(uuid())
  tenantId           String
  campusId           String
  studentNumber      String       @unique
  firstName          String
  lastName           String
  dateOfBirth        DateTime
  gender             Gender
  photoUrl           String?
  nationalId         String
  parentName         String
  parentPhone        String
  parentEmail        String
  parentRelationship String
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  Attendance         Attendance[]
  enrollments        Enrollment[]
  Grade              Grade[]
  Invoice            Invoice[]
  campus             Campus       @relation(fields: [campusId], references: [id])
}

model Enrollment {
  id             String           @id @default(uuid())
  studentId      String
  classroomId    String
  academicYearId String
  status         EnrollmentStatus @default(ACTIVE)
  enrollmentDate DateTime         @default(now())
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id])
  classroom      Classroom        @relation(fields: [classroomId], references: [id])
  student        Student          @relation(fields: [studentId], references: [id])

  @@unique([studentId, academicYearId])
}

model User {
  id        String   @id @default(uuid())
  tenantId  String?
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      UserRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id          String     @id @default(uuid())
  tenantId    String
  name        String
  code        String
  description String?
  employees   Employee[]
}

model Employee {
  id              String            @id @default(uuid())
  tenantId        String
  employeeNumber  String            @unique
  firstName       String
  lastName        String
  email           String
  phoneNumber     String
  dateOfBirth     DateTime
  gender          Gender
  hireDate        DateTime
  employeeType    EmployeeType
  photoUrl        String?
  isActive        Boolean           @default(true)
  departmentId    String
  campusId        String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  contracts       Contract[]
  department      Department        @relation(fields: [departmentId], references: [id])
  LeaveRequest    LeaveRequest[]
  Payslip         Payslip[]
  StaffAttendance StaffAttendance[]
  Timetable       Timetable[]
}

model Contract {
  id           String         @id @default(uuid())
  tenantId     String
  employeeId   String
  contractType ContractType
  startDate    DateTime
  endDate      DateTime?
  baseSalary   Float
  currency     String         @default("XOF")
  status       ContractStatus @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  employee     Employee       @relation(fields: [employeeId], references: [id])
}

model Subject {
  id          String      @id @default(uuid())
  tenantId    String
  name        String
  code        String
  coefficient Float       @default(1.0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  grades      Grade[]
  Timetable   Timetable[]
}

model Grade {
  id             String       @id @default(uuid())
  studentId      String
  subjectId      String
  academicYearId String
  trimestre      Int          @default(1)
  examType       ExamType
  score          Float
  maxScore       Float        @default(20.0)
  comment        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id])
  subject        Subject      @relation(fields: [subjectId], references: [id])
}

model Payslip {
  id                   String   @id @default(uuid())
  tenantId             String
  employeeId           String
  periodStart          DateTime
  periodEnd            DateTime
  baseSalary           Float
  taxableBonuses       Float    @default(0)
  nonTaxableBonuses    Float    @default(0)
  grossSalary          Float
  inpsEmployee         Float    @default(0)
  amoEmployee          Float    @default(0)
  totalDeductions      Float    @default(0)
  fiscalBase           Float    @default(0)
  its                  Float    @default(0)
  netSalary            Float
  inpsEmployer         Float    @default(0)
  amoEmployer          Float    @default(0)
  totalEmployerCharges Float    @default(0)
  numberOfChildren     Int      @default(0)
  status               String   @default("DRAFT")
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  employee             Employee @relation(fields: [employeeId], references: [id])
}

model Invoice {
  id            String    @id @default(uuid())
  tenantId      String
  studentId     String
  invoiceNumber String    @unique
  title         String
  type          String    @default("TUITION")
  amount        Float
  status        String    @default("UNPAID")
  dueDate       DateTime
  paidDate      DateTime?
  paymentMethod String?
  notes         String?
  createdAt     DateTime  @default(now())

  student  Student   @relation(fields: [studentId], references: [id])
  payments Payment[]
}

model Payment {
  id            String   @id @default(uuid())
  tenantId      String
  invoiceId     String
  amount        Float
  paymentDate   DateTime @default(now())
  method        String   @default("ESPECES") // ESPECES, ORANGE_MONEY, MOOV_MONEY, VIREMENT, CHEQUE
  reference     String?  // Numéro de reçu, ID de transaction
  notes         String?
  
  createdAt     DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Timetable {
  id          String    @id @default(uuid())
  tenantId    String
  classroomId String
  subjectId   String
  employeeId  String
  dayOfWeek   Int
  startTime   String
  endTime     String
  classroom   Classroom @relation(fields: [classroomId], references: [id])
  teacher     Employee  @relation(fields: [employeeId], references: [id])
  subject     Subject   @relation(fields: [subjectId], references: [id])
}

model Attendance {
  id          String    @id @default(uuid())
  tenantId    String
  studentId   String
  classroomId String
  date        DateTime
  status      String    @default("PRESENT")
  notes       String?
  classroom   Classroom @relation(fields: [classroomId], references: [id])
  student     Student   @relation(fields: [studentId], references: [id])
}

model StaffAttendance {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  date       DateTime
  checkIn    String?
  checkOut   String?
  status     String   @default("PRESENT")
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model LeaveRequest {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  startDate  DateTime
  endDate    DateTime
  type       String
  status     String   @default("PENDING")
  reason     String?
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Expense {
  id          String   @id @default(uuid())
  tenantId    String
  description String
  amount      Float
  date        DateTime @default(now())
  category    String
  status      String   @default("PAID")
  createdAt   DateTime @default(now())
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SchoolType {
  PUBLIC
  PRIVATE
  CONFESSIONAL
  INTERNATIONAL
  PRESCOLAIRE
  PRIMAIRE
  FONDAMENTAL
  LYCEE
  TECHNIQUE
  SANTE
  AGRO
  UNIVERSITE
}

enum Trimester {
  T1
  T2
  T3
}

enum EnrollmentStatus {
  ACTIVE
  PROMOTED
  REPEATED
  WITHDRAWN
  TRANSFERRED
}

enum EmployeeType {
  TEACHER
  ADMINISTRATIVE
  SUPPORT
  DIRECTOR
  CENSEUR
  SURVEILLANT_GENERAL
  DIRECTEUR_DES_ETUDES
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  HR_MANAGER
  ACCOUNTANT
  TEACHER
  STUDENT
  CENSEUR
  SURVEILLANT
  PARENT
}

enum ContractType {
  CDI
  CDD
  TEMPORARY
  INTERN
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  SUSPENDED
}

enum ExamType {
  CONTINUOUS
  MIDTERM
  FINAL
}
