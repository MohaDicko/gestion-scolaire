generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id              String         @id @default(uuid())
  name            String
  code            String         @unique
  address         String
  city            String
  country         String
  phoneNumber     String
  email           String
  type            SchoolType
  drenCode        String?
  isActive        Boolean        @default(true)
  isSetupComplete Boolean        @default(false)
  logoUrl         String?
  motto           String?
  nationalRNE     String?
  subdomain       String?        @unique
  customDomain    String?        @unique
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  plan            Plan           @default(STARTER)
  primaryColor    String?        @default("#4f8ef7")
  secondaryColor  String?        @default("#0f172a")
  academicYears   AcademicYear[]
  campuses        Campus[]
}

model Campus {
  id          String      @id @default(uuid())
  tenantId    String
  name        String
  address     String
  city        String
  region      String
  phoneNumber String
  email       String?
  managerName String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  school      School      @relation(fields: [tenantId], references: [id])
  classrooms  Classroom[]
  students    Student[]
}

model AcademicYear {
  id          String       @id @default(uuid())
  tenantId    String
  name        String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean      @default(false)
  school      School       @relation(fields: [tenantId], references: [id])
  classrooms  Classroom[]
  enrollments Enrollment[]
  grades      Grade[]
}

model Classroom {
  id             String       @id @default(uuid())
  tenantId       String
  campusId       String
  academicYearId String
  name           String
  level          String
  stream         String?
  series         String?
  maxCapacity    Int
  Attendance     Attendance[]
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  campus         Campus       @relation(fields: [campusId], references: [id])
  enrollments    Enrollment[]
  Timetable      Timetable[]
  lessonLogs     LessonLog[]
}

model Student {
  id                 String       @id @default(uuid())
  tenantId           String
  campusId           String
  studentNumber      String       @unique
  firstName          String
  lastName           String
  dateOfBirth        DateTime
  gender             Gender
  photoUrl           String?
  nationalId         String
  parentName         String
  parentPhone        String
  parentEmail        String
  parentRelationship String
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  Attendance         Attendance[]
  enrollments        Enrollment[]
  Grade              Grade[]
  Invoice            Invoice[]
  loans              Loan[]
  campus             Campus       @relation(fields: [campusId], references: [id])
}

model Enrollment {
  id             String           @id @default(uuid())
  studentId      String
  classroomId    String
  academicYearId String
  status         EnrollmentStatus @default(ACTIVE)
  enrollmentDate DateTime         @default(now())
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id])
  classroom      Classroom        @relation(fields: [classroomId], references: [id])
  student        Student          @relation(fields: [studentId], references: [id])

  @@unique([studentId, academicYearId])
}

model User {
  id        String   @id @default(uuid())
  tenantId  String?
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      UserRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  conversations Conversation[] @relation("UserConversations")
  sentMessages  Message[]      @relation("SentMessages")
  pushSubscriptions PushSubscription[]
}

model Department {
  id          String     @id @default(uuid())
  tenantId    String
  name        String
  code        String
  description String?
  employees   Employee[]
}

model Employee {
  id              String            @id @default(uuid())
  tenantId        String
  employeeNumber  String            @unique
  firstName       String
  lastName        String
  email           String
  phoneNumber     String
  dateOfBirth     DateTime
  gender          Gender
  hireDate        DateTime
  employeeType    EmployeeType
  photoUrl        String?
  isActive        Boolean           @default(true)
  departmentId    String
  campusId        String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  contracts       Contract[]
  department      Department        @relation(fields: [departmentId], references: [id])
  LeaveRequest    LeaveRequest[]
  Payslip         Payslip[]
  StaffAttendance StaffAttendance[]
  Timetable       Timetable[]
  lessonLogs      LessonLog[]
  loans           Loan[]
}

model Contract {
  id           String         @id @default(uuid())
  tenantId     String
  employeeId   String
  contractType ContractType
  startDate    DateTime
  endDate      DateTime?
  baseSalary   Float
  currency     String         @default("XOF")
  status       ContractStatus @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  employee     Employee       @relation(fields: [employeeId], references: [id])
}

model Subject {
  id          String      @id @default(uuid())
  tenantId    String
  name        String
  code        String
  coefficient Float       @default(1.0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  grades      Grade[]
  Timetable   Timetable[]
  lessonLogs  LessonLog[]
}

model Grade {
  id             String       @id @default(uuid())
  studentId      String
  subjectId      String
  academicYearId String
  trimestre      Int          @default(1)
  examType       ExamType
  score          Float
  maxScore       Float        @default(20.0)
  comment        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id])
  subject        Subject      @relation(fields: [subjectId], references: [id])
}

model Payslip {
  id                   String   @id @default(uuid())
  tenantId             String
  employeeId           String
  periodStart          DateTime
  periodEnd            DateTime
  baseSalary           Float
  taxableBonuses       Float    @default(0)
  nonTaxableBonuses    Float    @default(0)
  grossSalary          Float
  inpsEmployee         Float    @default(0)
  amoEmployee          Float    @default(0)
  totalDeductions      Float    @default(0)
  fiscalBase           Float    @default(0)
  its                  Float    @default(0)
  netSalary            Float
  inpsEmployer         Float    @default(0)
  amoEmployer          Float    @default(0)
  totalEmployerCharges Float    @default(0)
  numberOfChildren     Int      @default(0)
  status               String   @default("DRAFT")
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  employee             Employee @relation(fields: [employeeId], references: [id])
}

model Invoice {
  id            String    @id @default(uuid())
  tenantId      String
  studentId     String
  invoiceNumber String    @unique
  title         String
  type          String    @default("TUITION")
  amount        Float
  status        String    @default("UNPAID")
  dueDate       DateTime
  paidDate      DateTime?
  paymentMethod String?
  notes         String?
  createdAt     DateTime  @default(now())

  student  Student   @relation(fields: [studentId], references: [id])
  payments Payment[]
}

model Payment {
  id            String   @id @default(uuid())
  tenantId      String
  invoiceId     String
  amount        Float
  paymentDate   DateTime @default(now())
  method        String   @default("ESPECES") // ESPECES, ORANGE_MONEY, MOOV_MONEY, VIREMENT, CHEQUE
  reference     String?  // Numéro de reçu, ID de transaction
  notes         String?
  
  createdAt     DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Timetable {
  id          String    @id @default(uuid())
  tenantId    String
  classroomId String
  subjectId   String
  employeeId  String
  dayOfWeek   Int
  startTime   String
  endTime     String
  classroom   Classroom @relation(fields: [classroomId], references: [id])
  teacher     Employee  @relation(fields: [employeeId], references: [id])
  subject     Subject   @relation(fields: [subjectId], references: [id])
}

model Attendance {
  id          String    @id @default(uuid())
  tenantId    String
  studentId   String
  classroomId String
  date        DateTime
  status      String    @default("PRESENT")
  notes       String?
  classroom   Classroom @relation(fields: [classroomId], references: [id])
  student     Student   @relation(fields: [studentId], references: [id])
}

model LessonLog {
  id          String    @id @default(uuid())
  tenantId    String
  classroomId String
  subjectId   String
  employeeId  String
  date        DateTime  @default(now())
  title       String
  content     String    @db.Text
  homework    String?   @db.Text
  status      String    @default("COMPLETED") // COMPLETED, PLANNED, CANCELLED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  classroom Classroom @relation(fields: [classroomId], references: [id])
  subject   Subject   @relation(fields: [subjectId], references: [id])
  teacher   Employee  @relation(fields: [employeeId], references: [id])
}

model StaffAttendance {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  date       DateTime
  checkIn    String?
  checkOut   String?
  status     String   @default("PRESENT")
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model LeaveRequest {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  startDate  DateTime
  endDate    DateTime
  type       String
  status     String   @default("PENDING")
  reason     String?
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Expense {
  id          String   @id @default(uuid())
  tenantId    String
  description String
  amount      Float
  date        DateTime @default(now())
  category    String
  status      String   @default("PAID")
  createdAt   DateTime @default(now())
}

model StockItem {
  id            String             @id @default(uuid())
  tenantId      String
  name          String
  category      String             // Uniform, Textbook, Stationery, Equipment
  sku           String?            @unique
  description   String?
  unitPrice     Float              @default(0)
  quantity      Int                @default(0)
  minThreshold  Int                @default(5)
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  transactions  StockTransaction[]
}

model StockTransaction {
  id          String   @id @default(uuid())
  tenantId    String
  itemId      String
  type        String   // IN, OUT, ADJUSTMENT
  quantity    Int
  date        DateTime @default(now())
  performer   String?  // Name of person who did the action
  notes       String?
  
  item        StockItem @relation(fields: [itemId], references: [id])
}

model Book {
  id              String      @id @default(uuid())
  tenantId        String
  title           String
  author          String
  isbn            String?     @unique
  category        String      // Fiction, Science, History, etc.
  totalCopies     Int         @default(1)
  availableCopies Int         @default(1)
  shelfLocation   String?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  loans           Loan[]
}

model Loan {
  id            String    @id @default(uuid())
  tenantId      String
  bookId        String
  studentId     String?
  employeeId    String?
  loanDate      DateTime  @default(now())
  dueDate       DateTime
  returnDate    DateTime?
  status        String    @default("BORROWED") // BORROWED, RETURNED, OVERDUE, LOST

  book          Book      @relation(fields: [bookId], references: [id])
  student       Student?  @relation(fields: [studentId], references: [id])
  employee      Employee? @relation(fields: [employeeId], references: [id])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SchoolType {
  PUBLIC
  PRIVATE
  CONFESSIONAL
  INTERNATIONAL
  PRESCOLAIRE
  PRIMAIRE
  FONDAMENTAL
  LYCEE
  TECHNIQUE
  SANTE
  AGRO
  UNIVERSITE
}

enum Trimester {
  T1
  T2
  T3
}

enum EnrollmentStatus {
  ACTIVE
  PROMOTED
  REPEATED
  WITHDRAWN
  TRANSFERRED
}

enum EmployeeType {
  TEACHER
  ADMINISTRATIVE
  SUPPORT
  DIRECTOR
  CENSEUR
  SURVEILLANT_GENERAL
  DIRECTEUR_DES_ETUDES
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  HR_MANAGER
  ACCOUNTANT
  TEACHER
  STUDENT
  CENSEUR
  SURVEILLANT
  PARENT
}

enum ContractType {
  CDI
  CDD
  TEMPORARY
  INTERN
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  SUSPENDED
}

enum ExamType {
  CONTINUOUS
  MIDTERM
  FINAL
}

enum Plan {
  STARTER
  BUSINESS
  ELITE
}

model Conversation {
  id        String    @id @default(uuid())
  tenantId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  participants User[] @relation("UserConversations")
  messages     Message[]

  @@index([tenantId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  isRead         Boolean      @default(false)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}

model AuditLog {
  id           String      @id @default(uuid())
  tenantId     String      // Pour isoler les logs par école
  userId       String?     // L'utilisateur qui a fait l'action (peut être null si système)
  userRole     String?     // Le rôle de l'utilisateur au moment de l'action
  userEmail    String?
  action       AuditAction
  entityType   String      // ex: "Payment", "Grade", "Student", "Payslip"
  entityId     String      // l'ID de l'objet modifié
  oldValues    Json?       // Valeurs avant modification (pour l'historique)
  newValues    Json?       // Valeurs après modification
  ipAddress    String?
  userAgent    String?
  description  String?     // Description lisible de l'action
  createdAt    DateTime    @default(now())

  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  APPROVE
  REJECT
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
